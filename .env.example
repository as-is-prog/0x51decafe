# Server
PORT=3000
HOST=0.0.0.0

# Auth Token (optional)
# 設定すると毎回この固定トークンを使用。未設定の場合は起動ごとに自動生成（ローテーション）。
# AUTH_TOKEN=

# Default Inhabitant
DEFAULT_INHABITANT=nor

# CLI Engine
CLAUDE_PATH=claude
# CLI_ENGINE=claude-cli

# Web Push (optional)
# VAPID_EMAIL=mailto:your-email@example.com

# LINE Messaging (optional)
# LINE_CHANNEL_ACCESS_TOKEN=
